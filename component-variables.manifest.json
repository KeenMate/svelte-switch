{
	"$schema": "https://raw.githubusercontent.com/keenmate/schemas/main/component-variables.schema.json",
	"component": "@keenmate/svelte-switch",
	"prefix": "switch",
	"baseVariables": [
		{
			"name": "base-accent-color",
			"required": false,
			"usage": "Accent color used for focus ring and (when no itemStyles) the active state"
		},
		{
			"name": "base-disabled-bg",
			"required": false,
			"usage": "Background of the off / unselected switch surface"
		},
		{
			"name": "base-input-bg",
			"required": false,
			"usage": "Thumb fill"
		},
		{
			"name": "base-border-color",
			"required": false,
			"usage": "Default thumb border color (when itemStyles.thumbBorderColor is not set)"
		},
		{
			"name": "base-border-radius-sm",
			"required": false,
			"usage": "Corner radius of the switch shell, thumb, and step segments"
		},
		{
			"name": "base-shadow-sm",
			"required": false,
			"usage": "Drop shadow under the thumb"
		},
		{
			"name": "base-text-color-1",
			"required": false,
			"usage": "Active label text color"
		},
		{
			"name": "base-text-color-3",
			"required": false,
			"usage": "Inactive label text color"
		},
		{
			"name": "base-font-family",
			"required": false,
			"usage": "Font family for default labels"
		},
		{
			"name": "base-font-size-sm",
			"required": false,
			"usage": "Base font size for default labels (scales with switch size)"
		}
	],
	"componentVariables": [
		{ "name": "switch-accent-color", "category": "accent", "usage": "Accent color (focus ring, active state)" },
		{ "name": "switch-bg-off", "category": "surface", "usage": "Switch background when off / not on selected step" },
		{ "name": "switch-thumb-bg", "category": "surface", "usage": "Thumb fill color" },
		{ "name": "switch-thumb-border-color", "category": "border", "usage": "Default thumb border color" },
		{ "name": "switch-focus-color", "category": "focus", "usage": "Focus ring color" },
		{ "name": "switch-focus-ring", "category": "focus", "usage": "Full focus ring shorthand (box-shadow)" },
		{ "name": "switch-border-radius", "category": "radius", "usage": "Corner radius for switch, thumb, and step segments" },
		{ "name": "switch-shadow", "category": "elevation", "usage": "Thumb drop shadow" },
		{ "name": "switch-label-color", "category": "label", "usage": "Inactive label text color" },
		{ "name": "switch-label-active-color", "category": "label", "usage": "Active label text color" },
		{ "name": "switch-label-font-family", "category": "label", "usage": "Label font family" },
		{ "name": "switch-label-font-size", "category": "label", "usage": "Label base font size (scales with --scale)" },
		{ "name": "current-bg-color", "category": "per-step", "usage": "Per-instance background color (set via itemStyles.backgroundColor)" },
		{ "name": "current-thumb-color", "category": "per-step", "usage": "Per-instance thumb color (set via itemStyles.thumbColor)" },
		{ "name": "current-thumb-border-color", "category": "per-step", "usage": "Per-instance thumb border (set via itemStyles.thumbBorderColor)" },
		{ "name": "step-bg-color", "category": "per-step", "usage": "Per-step segment background (set via itemStyles[index].backgroundColor)" },
		{ "name": "step-border-color", "category": "per-step", "usage": "Per-step segment border (set via itemStyles[index].thumbBorderColor)" },
		{ "name": "scale", "category": "sizing", "usage": "Size multiplier (size / 50)" },
		{ "name": "steps", "category": "sizing", "usage": "Number of steps in MultiSwitch (auto-set from props)" }
	]
}
