{
	"name": "@keenmate/svelte-switch",
	"version": "1.1.0",
	"description": "A modern, customizable switch component for Svelte 5 with support for both binary and multi-step switches",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"keywords": [
		"svelte",
		"svelte5",
		"switch",
		"toggle",
		"multiswitch",
		"component",
		"ui",
		"typescript",
		"sass"
	],
	"author": "Keenmate",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/keenmate/svelte-switch.git"
	},
	"homepage": "https://github.com/keenmate/svelte-switch#readme",
	"bugs": {
		"url": "https://github.com/keenmate/svelte-switch/issues"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"package": "svelte-kit sync && svelte-package && publint",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/package": "^2.5.1",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"publint": "^0.1.16",
		"sass": "^1.92.1",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^7.0.4"
	},
	"svelte": "./dist/index.js"
}
